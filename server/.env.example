# Copy to .env and fill in real values before running the server.

PORT=8585
NODE_ENV=production

# Path to the app's SQLite database (inside the Docker volume)
BUFF_DB_PATH=/data/buff.db

# Path to Calibre-Web Automated's app.db (read-only, for auth)
CWA_DB_PATH=/cwa-config/app.db

# Secret used to sign session JWTs — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-with-openssl-rand-hex-32

# Directory containing the pre-built client (Vite output)
STATIC_DIR=/app/client/dist

# Anthropic API key — required for Phase 8 exercise discovery
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
