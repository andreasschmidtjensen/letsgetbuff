{
  "name": "letsgetbuff-monorepo",
  "private": true,
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client && npm run build -w server",
    "start": "npm run start -w server",
    "test": "npm run test -w client && npm run test -w shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}













































































































































































































































































































































